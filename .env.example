# 아래 값과 동일한 이름으로 GitHub repository secrets를 등록하세요.
# (Settings > Secrets and variables > Actions > New repository secret)
# 로컬 개발 환경에서는 이 파일을 .env로 복사해 docker compose / 애플리케이션에서 사용합니다.

# JWT 서명 키 (32자 이상 랜덤 문자열 권장: openssl rand -base64 48)
JWT_SECRET=your-secret-key-here-must-be-at-least-32-characters

# 초기 admin 계정 비밀번호
ADMIN_PASSWORD=your-admin-password

# 서버 포트 (배포 환경 기준. 로컬 개발은 application.yml 기본값(8083)을 그대로 사용)
PORT=8080

# ---- MySQL (배포 시 AWS RDS 등 외부 MySQL을 사용) ----
# RDS 엔드포인트 주소 (예: jeoljeolmode-db.xxxxxxxx.us-east-1.rds.amazonaws.com)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=capstone
DB_USERNAME=capstone
DB_PASSWORD=change-me
# SSL 모드: PREFERRED(로컬 기본값) | REQUIRED(RDS 권장, 암호화는 하되 인증서 검증은 생략)
# VERIFY_IDENTITY는 JVM/이미지에 RDS CA 인증서 체인이 없으면 핸드셰이크 실패(Path does not chain with any of the trust anchors)
DB_SSL_MODE=PREFERRED

# ---- Flyway ----
# 기존 ddl-auto 기반 DB를 처음 Flyway에 연결할 때 기준선을 자동 등록
FLYWAY_BASELINE_ON_MIGRATE=true

# ---- 로컬 개발 전용 (docker-compose.yml의 mysql 컨테이너) ----
# MySQL 컨테이너 root 계정 비밀번호. 배포(RDS 사용)에는 불필요.
MYSQL_ROOT_PASSWORD=change-me-root

# ---- 배포(CD) 전용 secrets ----
# Docker 기반 배포를 수행할 서버 정보. 아래 값들은 .env가 아닌 GitHub Secrets에만 등록하면 됩니다.
# DEPLOY_HOST=배포 서버 주소
# DEPLOY_USER=SSH 사용자
# DEPLOY_SSH_KEY=SSH private key (전체 내용)
# DEPLOY_PATH=서버에 docker-compose.yml/.env를 둘 경로
