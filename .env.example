# 아래 값들을 실제 운영 환경에서 환경변수로 설정하세요.
# 개발 환경에서는 application.yml의 기본값이 사용됩니다.

# JWT 서명 키 (32자 이상)
JWT_SECRET=your-secret-key-here-must-be-at-least-32-characters

# 초기 admin 계정 비밀번호
ADMIN_PASSWORD=your-admin-password

# MongoDB URI (mongo 프로파일 사용 시)
MONGODB_URI=mongodb://localhost:27017/capstone

# 서버 포트
PORT=8082
